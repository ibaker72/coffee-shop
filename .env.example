# ─── Database (Supabase) ──────────────────────────────────────────────────────
# Pooled connection via PgBouncer — used for all runtime queries
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-eu-west-2.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# Direct connection — bypasses pooler, REQUIRED for Prisma migrate commands
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-0-eu-west-2.pooler.supabase.com:5432/postgres"

# ─── NextAuth ─────────────────────────────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=""

# ─── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY="sk_test_..."
# NEXT_PUBLIC_ prefix required — used by @stripe/stripe-js in the browser
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
# IMPORTANT: This is a DIFFERENT value for local dev (from CLI) vs production (from Dashboard)
# Local:      stripe listen --forward-to localhost:3000/api/stripe/webhook
# Production: https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET="whsec_..."

# ─── Cloudinary ───────────────────────────────────────────────────────────────
# MUST have NEXT_PUBLIC_ prefix — used by CldImage component in browser
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
# NEVER prefix with NEXT_PUBLIC_ — would expose secret to browser
CLOUDINARY_API_SECRET=""
# Create a restricted upload preset in Cloudinary Dashboard for customer uploads
CLOUDINARY_UPLOAD_PRESET="qahwa-products"

# ─── Resend (Transactional Email) ─────────────────────────────────────────────
RESEND_API_KEY="re_..."
RESEND_FROM_EMAIL="orders@qahwa.co"
RESEND_FROM_NAME="Qahwa & Co"

# ─── App Config ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Qahwa & Co"
ADMIN_EMAIL="admin@qahwa.co"

# ─── On-demand ISR Revalidation ───────────────────────────────────────────────
# Generate with: openssl rand -base64 32
# Used to protect /api/revalidate from unauthorized calls
REVALIDATION_SECRET=""

# ─── Optional: Analytics ──────────────────────────────────────────────────────
# NEXT_PUBLIC_GA_MEASUREMENT_ID=""
# NEXT_PUBLIC_POSTHOG_KEY=""
# NEXT_PUBLIC_POSTHOG_HOST="https://app.posthog.com"
